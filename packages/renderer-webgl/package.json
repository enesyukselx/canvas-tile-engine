{
    "name": "@canvas-tile-engine/renderer-webgl",
    "version": "0.1.0",
    "description": "Lightweight library for building interactive 2D grid-based maps and visualizations with WebGL",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git",
        "directory": "packages/renderer-webgl"
    },
    "homepage": "https://canvastileengine.dev",
    "bugs": {
        "url": "https://github.com/enesyukselx/canvas-tile-engine/issues"
    },
    "keywords": [
        "canvas",
        "webgl",
        "tile",
        "engine",
        "2d",
        "map",
        "game",
        "grid",
        "visualization",
        "interactive",
        "pan",
        "zoom",
        "gpu"
    ],
    "sideEffects": false,
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "format": "oxfmt",
        "format:check": "oxfmt --check"
    },
    "peerDependencies": {
        "@canvas-tile-engine/core": ">=0.3.0"
    },
    "dependencies": {
        "@canvas-tile-engine/core": "workspace:*"
    }
}
