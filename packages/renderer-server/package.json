{
    "name": "@canvas-tile-engine/renderer-server",
    "version": "0.1.0",
    "description": "Headless server-side (Node.js) renderer for Canvas Tile Engine — draws maps to a PNG/Buffer with no browser",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git",
        "directory": "packages/renderer-server"
    },
    "homepage": "https://canvastileengine.dev",
    "bugs": {
        "url": "https://github.com/enesyukselx/canvas-tile-engine/issues"
    },
    "keywords": [
        "canvas",
        "tile",
        "engine",
        "2d",
        "map",
        "grid",
        "visualization",
        "server",
        "headless",
        "node",
        "ssr",
        "png",
        "og-image",
        "napi-rs"
    ],
    "sideEffects": false,
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "engines": {
        "node": ">=18"
    },
    "peerDependencies": {
        "@canvas-tile-engine/core": ">=0.3.0"
    },
    "dependencies": {
        "@canvas-tile-engine/core": "workspace:*",
        "@napi-rs/canvas": "^0.1.60"
    },
    "devDependencies": {
        "@types/node": "^25.3.3"
    }
}
