{
    "name": "@canvas-tile-engine/tiled",
    "version": "0.0.0",
    "description": "Load Tiled (.tmj) maps into Canvas Tile Engine — tile layers, object layers, flips, animations",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git",
        "directory": "packages/tiled"
    },
    "homepage": "https://canvastileengine.dev",
    "bugs": {
        "url": "https://github.com/enesyukselx/canvas-tile-engine/issues"
    },
    "keywords": [
        "canvas",
        "tile",
        "engine",
        "2d",
        "map",
        "grid",
        "tiled",
        "tmj",
        "tmx",
        "tilemap",
        "mapeditor"
    ],
    "sideEffects": false,
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint",
        "test": "vitest",
        "test:coverage": "vitest run --coverage",
        "format": "oxfmt",
        "format:check": "oxfmt --check"
    },
    "engines": {
        "node": ">=18"
    },
    "peerDependencies": {
        "@canvas-tile-engine/core": ">=0.9.0"
    },
    "dependencies": {
        "@canvas-tile-engine/core": "workspace:^",
        "fflate": "^0.8.2"
    },
    "devDependencies": {
        "@types/node": "^25.3.3"
    }
}
