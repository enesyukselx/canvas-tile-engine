{
    "name": "@canvas-tile-engine/react-native",
    "version": "0.5.0",
    "description": "React Native bindings for Canvas Tile Engine - interactive 2D grid-based maps with Skia",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git",
        "directory": "packages/react-native"
    },
    "homepage": "https://canvastileengine.dev",
    "bugs": {
        "url": "https://github.com/enesyukselx/canvas-tile-engine/issues"
    },
    "keywords": [
        "canvas",
        "tile",
        "engine",
        "react-native",
        "skia",
        "2d",
        "map",
        "game",
        "grid"
    ],
    "sideEffects": false,
    "main": "dist/index.cjs",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "oxlint",
        "format": "oxfmt",
        "format:check": "oxfmt --check"
    },
    "peerDependencies": {
        "@canvas-tile-engine/core": ">=0.4.0",
        "@canvas-tile-engine/renderer-skia": ">=0.1.0",
        "@shopify/react-native-skia": ">=2.0.0-next.0",
        "react": ">=18.0.0",
        "react-native": ">=0.78.0",
        "react-native-gesture-handler": ">=2.14.0"
    },
    "dependencies": {
        "@canvas-tile-engine/core": "workspace:^",
        "@canvas-tile-engine/renderer-skia": "workspace:^"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "react": "^19.0.0",
        "react-native": "^0.78.0",
        "react-native-gesture-handler": "^2.24.0"
    }
}
