{
    "name": "canvas-tile-engine",
    "version": "0.0.1",
    "private": true,
    "description": "Canvas Tile Engine monorepo",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git"
    },
    "scripts": {
        "build": "turbo run build --filter=./packages/*",
        "build:docs": "turbo run build --filter=docs",
        "dev": "concurrently \"pnpm dev:lib\" \"pnpm --filter vanilla-js-game-map dev\"",
        "dev:lib": "turbo run dev --filter=./packages/* --filter=!@canvas-tile-engine/renderer-server",
        "dev:example": "node run-example.js",
        "lint": "turbo run lint",
        "typecheck": "turbo run typecheck",
        "format": "turbo run format",
        "format:check": "turbo run format:check",
        "test": "turbo run test",
        "test:coverage": "turbo run test:coverage"
    },
    "keywords": [],
    "packageManager": "pnpm@10.23.0",
    "engines": {
        "node": ">=20.19.0"
    },
    "dependencies": {
        "concurrently": "^10.0.3",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@vitest/coverage-v8": "^4.1.9",
        "oxfmt": "^0.57.0",
        "oxlint": "^1.72.0",
        "turbo": "^2.10.2",
        "vitest": "^4.1.9"
    }
}
