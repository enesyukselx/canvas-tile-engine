{
    "name": "canvas-tile-engine",
    "version": "0.0.1",
    "private": true,
    "description": "Canvas Tile Engine monorepo",
    "author": "Enes Yüksel",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/enesyukselx/canvas-tile-engine.git"
    },
    "scripts": {
        "build": "turbo run build --filter=./packages/*",
        "build:docs": "turbo run build --filter=docs",
        "dev": "concurrently \"pnpm dev:lib\" \"pnpm --filter vanilla-js-game-map dev\"",
        "dev:lib": "pnpm --filter @canvas-tile-engine/core dev & pnpm --filter @canvas-tile-engine/renderer-canvas dev & pnpm --filter @canvas-tile-engine/renderer-webgl dev & pnpm --filter @canvas-tile-engine/react dev",
        "dev:example": "node run-example.js",
        "lint": "pnpm exec eslint .",
        "typecheck": "turbo run typecheck",
        "test": "turbo run test",
        "test:coverage": "turbo run test:coverage"
    },
    "keywords": [],
    "packageManager": "pnpm@10.23.0",
    "dependencies": {
        "concurrently": "^9.2.1",
        "tsup": "^8.5.1",
        "typescript": "^5.9.3"
    },
    "devDependencies": {
        "@types/node": "^25.3.3",
        "@vitest/coverage-v8": "^4.0.18",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "globals": "^16.5.0",
        "turbo": "^2.10.2",
        "typescript-eslint": "^8.56.1",
        "vitest": "^4.0.18"
    }
}
